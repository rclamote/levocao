{
  "functions": {
    "api/local.js": {
      "includeFiles": "index.html"
    }
  },
  "rewrites": [
    {
      "source": "/local/:slug",
      "destination": "/api/local?slug=:slug"
    },
    {
      "source": "/sitemap.xml",
      "destination": "/api/sitemap"
    },
    {
      "source": "/:path*",
      "destination": "/index.html"
    }
  ]
}
